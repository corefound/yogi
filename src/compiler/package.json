{
  "name": "yogi",
  "version": "0.0.1",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "repository": "https://github.com/corefound/yogi.git",
  "author": "Brayhan De Aza <brayhandeaza@gmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "rm -rf ./build && tsc -p tsconfig.json && tsc-alias -p tsconfig.json && cp -r ./src/ts/local ./build/ts/local",
    "dev": "nodemon --exec ts-node ./src/index.ts ../../tests/main.io",
    "pkg": "npx pkg build/index.js --targets node18-linux-x64,node18-macos-x64,node18-macos-arm64,node18-win-x64, --output ./bin/parser"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "global": "^4.4.0",
    "node-addon-api": "^8.5.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "eslint": "^4.17.0",
    "mocha": "^5.0.0",
    "node": "^25.4.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "zod": "^4.3.6"
  }
}
