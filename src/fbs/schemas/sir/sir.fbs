include "constants.fbs";

namespace Yogi.Sir;

enum PrimitiveType : byte {
  unknown = 0,
  number = 1,
  string = 2,
  boolean = 3,
  null_type = 4,
  undefined_type = 5,
  void_type = 6
}

table TypeRef {
  primitive:PrimitiveType = unknown;
}

table VariableDeclaration {
  name:string;
  type:TypeRef;
  value:Constant;
}

table Module {
  variables:[VariableDeclaration];
}

root_type Module;