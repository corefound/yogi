// sir/constants.fbs

include "common.fbs";

namespace Yogi.Sir;

table NumberConstant {
  value:double;
}

table StringConstant {
  value:string;
}

table BooleanConstant {
  value:bool;
}

table NullConstant {
}

table UndefinedConstant {
}

union ConstantValue {
  NumberConstant,
  StringConstant,
  BooleanConstant,
  NullConstant,
  UndefinedConstant
}

table Constant {
  type:TypeRef;
  raw:string;
  source:string;
  position:SourcePosition;
  value:ConstantValue;
}