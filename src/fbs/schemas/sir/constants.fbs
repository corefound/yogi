// sir/constants.fbs

namespace Yogi.Sir;

table NumberConstant {
  value:double;
}

table StringConstant {
  value:string;
}

table BooleanConstant {
  value:bool;
}

table NullConstant {
}

table UndefinedConstant {
}

union ConstantValue {
  NumberConstant,
  StringConstant,
  BooleanConstant,
  NullConstant,
  UndefinedConstant
}

table Constant {
  value:ConstantValue;
}