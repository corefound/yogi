// ast/ast.fbs

include "literals.fbs";

namespace Yogi.Ast;

table Identifier {
  name:string;
}

union Expression {
  Identifier,
  Literal
}

table VariableDeclaration {
  name:string;
  type_annotation:string;
  initializer:Expression;
}

table AstModule {
  source_path:string;
  body:[VariableDeclaration];
}

root_type AstModule;