// ast/literals.fbs

namespace Yogi.Ast;

table NumberLiteral {
  value:double;
  raw:string;
}

table StringLiteral {
  value:string;
  raw:string;
}

table BooleanLiteral {
  value:bool;
  raw:string;
}

table NullLiteral {
  raw:string;
}

table UndefinedLiteral {
  raw:string;
}

union LiteralValue {
  NumberLiteral,
  StringLiteral,
  BooleanLiteral,
  NullLiteral,
  UndefinedLiteral
}

table Literal {
  value:LiteralValue;
}