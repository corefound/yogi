{
  "compilerOptions": {
    "types": ["node"],
    "module": "CommonJS",
    "target": "esnext",
    "outDir": "build",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "strictNullChecks": false,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "noImplicitAny": true,

    "rootDir": "./",

    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "tests", "**/*.io"]
}
